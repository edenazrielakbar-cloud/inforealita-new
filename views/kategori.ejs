<!-- Breadcrumb -->
<div class="breadcrumb">
    <a href="/">Home</a>
    <span class="separator">/</span>
    <span>Kategori <%= kategori %></span>
</div>

<!-- Hero Section Kategori -->
<section class="category-hero">
    <h1>Kategori: <%= kategori %></h1>
    <p>Menampilkan semua berita dalam kategori <%= kategori %></p>
</section>

<!-- Page Info -->
<div class="page-info">
    <p>Menampilkan halaman <%= currentPage %> dari <%= totalPages %> (total <%= berita.length %> berita)</p>
</div>

<!-- Daftar Berita per Kategori -->
<section class="berita-kategori">
    <% if (berita.length > 0) { %>
        <div class="berita-grid">
            <% berita.forEach(function(item) { %>
            <article class="berita-card">
                <a href="/berita/<%= item.slug %>">
                    <div class="thumbnail">
                        <% if (item.thumbnail) { %>
                            <img src="<%= item.thumbnail %>" alt="<%= item.judul %>">
                        <% } else { %>
                            <div class="no-image">
                                <i class="fas fa-image"></i>
                                <span>Tidak Ada Gambar</span>
                            </div>
                        <% } %>
                    </div>
                    <div class="content">
                        <h3><%= item.judul %></h3>
                        <div class="meta">
                            <span><i class="fas fa-calendar"></i> <%= new Date(item.createdAt).toLocaleDateString('id-ID') %></span>
                            <span><i class="fas fa-user"></i> <%= item.penulis %></span>
                            <span><i class="fas fa-eye"></i> <%= item.views %>x dilihat</span>
                        </div>
                        <p><%= item.konten.replace(/<[^>]*>/g, '').substring(0, 150) %>...</p>
                        <span class="read-more">Baca Selengkapnya →</span>
                    </div>
                </a>
            </article>
            <% }); %>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <div class="pagination">
            <% if (currentPage > 1) { %>
                <a href="?page=<%= currentPage - 1 %>" class="page-link">&laquo; Sebelumnya</a>
            <% } %>
            
            <% for(let i = 1; i <= totalPages; i++) { %>
                <a href="?page=<%= i %>" class="page-link <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
            <% } %>
            
            <% if (currentPage < totalPages) { %>
                <a href="?page=<%= currentPage + 1 %>" class="page-link">Selanjutnya &raquo;</a>
            <% } %>
        </div>
        <% } %>
        
    <% } else { %>
        <div class="no-news">
            <i class="fas fa-newspaper" style="font-size: 48px; color: #ccc; margin-bottom: 20px;"></i>
            <h3>Belum ada berita di kategori <%= kategori %></h3>
            <p>Belum ada berita yang dipublikasikan di kategori ini.</p>
            <a href="/" class="btn-primary">Kembali ke Home</a>
        </div>
    <% } %>
</section>