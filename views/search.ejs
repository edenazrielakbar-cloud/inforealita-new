<!-- Breadcrumb -->
<div class="breadcrumb">
    <a href="/">Home</a>
    <span class="separator">/</span>
    <span>Pencarian</span>
</div>

<!-- Page Info -->
<div class="page-info">
    <i class="fas fa-search"></i> Pencarian: "<%= query %>" - Halaman <%= currentPage %> dari <%= totalPages %> (Menemukan <%= berita.length %> berita)
</div>

<!-- Search Header -->
<section class="search-header">
    <h1><i class="fas fa-search"></i> Hasil Pencarian</h1>
    <p>Menampilkan hasil untuk kata kunci: "<strong><%= query %></strong>"</p>
</section>

<!-- Hasil Pencarian -->
<section class="search-results">
    <% if (berita.length > 0) { %>
        <div class="berita-grid">
            <% berita.forEach(function(item) { %>
            <article class="berita-card">
                <a href="/berita/<%= item.slug %>">
                    <div class="thumbnail">
                        <% if (item.thumbnail) { %>
                            <img src="<%= item.thumbnail %>" alt="<%= item.judul %>">
                        <% } else { %>
                            <div class="no-image">
                                <i class="fas fa-image"></i>
                                <span>Tidak Ada Gambar</span>
                            </div>
                        <% } %>
                    </div>
                    <div class="content">
                        <h3><%= item.judul %></h3>
                        <div class="meta">
                            <span><i class="fas fa-calendar"></i> <%= new Date(item.createdAt).toLocaleDateString('id-ID') %></span>
                            <span><i class="fas fa-user"></i> <%= item.penulis %></span>
                            <span><i class="fas fa-eye"></i> <%= item.views %>x</span>
                        </div>
                        <p><%= item.konten.replace(/<[^>]*>/g, '').substring(0, 100) %>...</p>
                        <span class="read-more">Baca Selengkapnya →</span>
                    </div>
                </a>
            </article>
            <% }); %>
        </div>
        
        <!-- Pagination -->
        <% if (totalPages > 1) { %>
        <div class="pagination">
            <% if (currentPage > 1) { %>
                <a href="?q=<%= query %>&page=<%= currentPage - 1 %>" class="page-link">
                    <i class="fas fa-chevron-left"></i>
                </a>
            <% } %>
            
            <% for(let i = 1; i <= totalPages; i++) { %>
                <a href="?q=<%= query %>&page=<%= i %>" class="page-link <%= i === currentPage ? 'active' : '' %>"><%= i %></a>
            <% } %>
            
            <% if (currentPage < totalPages) { %>
                <a href="?q=<%= query %>&page=<%= currentPage + 1 %>" class="page-link">
                    <i class="fas fa-chevron-right"></i>
                </a>
            <% } %>
        </div>
        <% } %>
        
    <% } else { %>
        <div class="no-results">
            <i class="fas fa-search"></i>
            <h3>Tidak ada hasil</h3>
            <p>Tidak ditemukan berita dengan kata kunci "<strong><%= query %></strong>"</p>
            <div class="search-suggestions">
                <h4>Saran:</h4>
                <ul>
                    <li>Pastikan kata kunci dieja dengan benar</li>
                    <li>Coba dengan kata kunci yang lebih umum</li>
                    <li>Coba dengan kata kunci lain</li>
                </ul>
            </div>
            <a href="/" class="btn-primary">Kembali ke Home</a>
        </div>
    <% } %>
</section>

<style>
.search-header {
    text-align: center;
    margin: 2rem 0;
    padding: 2rem;
    background: white;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
}

.search-header h1 {
    color: #2e7d32;
    margin-bottom: 0.5rem;
}

.search-header h1 i {
    margin-right: 0.5rem;
}

.search-header p {
    color: #666;
}

.no-results {
    text-align: center;
    padding: 3rem;
    background: white;
    border-radius: 10px;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    max-width: 600px;
    margin: 2rem auto;
}

.no-results i {
    font-size: 3rem;
    color: #ccc;
    margin-bottom: 1rem;
}

.no-results h3 {
    color: #333;
    margin-bottom: 0.5rem;
}

.no-results p {
    color: #666;
    margin-bottom: 1.5rem;
}

.search-suggestions {
    text-align: left;
    background: #f5f5f5;
    padding: 1.5rem;
    border-radius: 5px;
    margin: 1.5rem 0;
}

.search-suggestions h4 {
    color: #333;
    margin-bottom: 0.5rem;
}

.search-suggestions ul {
    margin-left: 1.5rem;
    color: #666;
}

.search-suggestions li {
    margin-bottom: 0.25rem;
}

.btn-primary {
    display: inline-block;
    padding: 0.75rem 1.5rem;
    background: #2e7d32;
    color: white;
    text-decoration: none;
    border-radius: 5px;
    transition: background 0.3s;
}

.btn-primary:hover {
    background: #1b5e20;
}
</style>